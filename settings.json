{
  "permissions": {
    "deny": [
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Bash(rm *.env*)",
      "Bash(rm .env*)",
      "Bash(rm **/.env*)",
      "Bash(mv *.env*)",
      "Bash(mv .env*)",
      "Bash(git rm *.env*)",
      "Bash(git rm .env*)"
    ],
    "allow": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(${CLAUDE_PLUGIN_ROOT}/scripts/*:*)",
      "Bash(git worktree:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue view:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(chmod:*)",
      "Bash(npm install:*)",
      "Bash(npm test)",
      "Bash(npm run:*)",
      "Bash(pip install:*)",
      "Bash(python:*)",
      "Bash(createdb:*)",
      "Bash(psql:*)",
      "Bash(pg_isready:*)",
      "Bash(osascript:*)",
      "Bash(terminal-notifier:*)",
      "Bash(docker-compose:*)",
      "Bash(source:*)"
    ]
  }
}
